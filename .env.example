# Vercel AI Gateway — optional base URL. When unset, @ai-sdk/gateway uses the default
# endpoint (https://ai-gateway.vercel.sh/v1/ai). Auth: VERCEL_OIDC_TOKEN (vc env pull / vc dev)
# or AI_GATEWAY_API_KEY. Do not invent JWKS URLs; use the SDK default + OIDC/key.
# AI_GATEWAY_BASE_URL=

# Optional gateway observability (Vercel AI Gateway dashboard attribution)
# AI_GATEWAY_TAGS=app:unified-ai,channel:gateway
# AI_GATEWAY_USER_FROM_SESSION=true
# AI_GATEWAY_USER=

# Postgres (Neon or Supabase Transaction pooler — must be postgres:// or postgresql://)
DATABASE_URL=

# Composio REST (tool catalog sync)
COMPOSIO_API_KEY=
# Optional comma-separated toolkit slugs when syncing (empty = all)
# COMPOSIO_SYNC_TOOLKIT_ALLOWLIST=vercel,github
# Optional override (default https://backend.composio.dev)
# COMPOSIO_API_BASE=

# Pinecone optional summaries namespace
PINECONE_API_KEY=
PINECONE_INDEX=
# PINECONE_NAMESPACE_SUMMARIES=summaries
# PINECONE_EMBED_MODEL=llama-text-embed-v2

# Cost estimates for dashboard (USD per 1M tokens)
# COST_INPUT_PER_M_TOKENS_USD=0.15
# COST_OUTPUT_PER_M_TOKENS_USD=0.6

# POST /api/admin/sync-composio
ADMIN_SECRET=

# Supabase Storage (full message transcripts)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
# STORE_FULL_MESSAGES=true

# Memory context injection (Pinecone RAG)
# ENABLE_MEMORY_CONTEXT=true

# Comma-separated tool name prefixes allowed for POST /api/tool-call (empty = all)
# ALLOWED_TOOL_PREFIXES=GITHUB_,SLACK_

# --- Datadog (optional) — server/CI: never expose DD_API_KEY to the browser ---
# DD_TRACE_ENABLED=true
# DD_API_KEY=
# DD_SITE=datadoghq.com
# DD_SERVICE=unified-ai-v1
# DD_ENV=development
# DD_VERSION=local

# RUM (browser) — safe via NEXT_PUBLIC_*
# NEXT_PUBLIC_DD_APPLICATION_ID=
# NEXT_PUBLIC_DD_CLIENT_TOKEN=
# NEXT_PUBLIC_DD_SITE=datadoghq.com
# NEXT_PUBLIC_DD_SERVICE=unified-ai-v1
# NEXT_PUBLIC_DD_ENV=development
# NEXT_PUBLIC_DD_VERSION=local
